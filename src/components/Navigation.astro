---
const NAV = [
    {
        name: "Blog",
        url: "/",
    },
    {
        name: "Projects",
        url: "/projects/",
    },
    {
        name: "About",
        url: "/about/",
    },
];
---

<nav class="py-2">
    <ul class="flex gap-x-4">
        {
            NAV.map((item) => (
                <li>
                    <a href={item.url} class="hover:underline">
                        {item.name}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<style>
    a {
        color: #73ba30;
    }
</style>
