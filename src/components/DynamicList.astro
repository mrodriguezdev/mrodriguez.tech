---
import ExternalLink from '@/components/ExternalLink.astro';

type TextPart = {
  type: "text";
  text: string;
};

type LinkPart = {
  type: "link";
  text: string;
  url: string;
};

type DescriptionPart = TextPart | LinkPart;

interface LinkItem {
  text: string;
  url: string;
}

interface ListItem {
  title?: string;
  description: string;
  url?: string;
  links?: LinkItem[];
}

export interface Props {
  items: ListItem[];
  listType?: "numbered" | "bulleted" | "plain";
}

const { items, listType = "numbered" } = Astro.props;

const isNumbered = listType === "numbered";
const isBulleted = listType === "bulleted";
const isPlain = listType === "plain";

function parseDescription(item: ListItem): DescriptionPart[] {
  const parts = item.description.split(/(\?\d+)/g);

  return parts.map((part) => {
    const match = part.match(/^\?(\d+)$/);

    if (match) {
      const index = Number(match[1]) - 1;
      const link = item.links?.[index];

      if (link) {
        return {
          type: "link",
          text: link.text,
          url: link.url,
        };
      }
    }

    return {
      type: "text",
      text: part,
    };
  });
}
---

{isNumbered && (
  <ol class="list-none p-0 m-0">
    {items.map((item, index) => (
      <li class="mb-2">
        {item.title && (
          <span class="font-semibold text-negro-profundo dark:text-blanco-puro">
            {index + 1}.{" "}
            {item.url ? (
              <ExternalLink href={item.url} text={item.title} />
            ) : (
              item.title
            )}
            {item.description ? ": " : ""}
          </span>
        )}

        <span class="text-base md:text-[16px] text-gris-oscuro dark:text-gris-claro">
          {parseDescription(item).map((part) =>
            part.type === "link" ? (
              <ExternalLink href={part.url} text={part.text} />
            ) : (
              part.text
            )
          )}
        </span>
      </li>
    ))}
  </ol>
)}

{isBulleted && (
  <ul class="list-none p-0 m-0">
    {items.map((item) => (
      <li class="mb-2 flex gap-3">
        <span class="select-none text-gris-oscuro dark:text-gris-claro leading-6">
          •
        </span>

        <div class="flex-1">
          {item.title && (
            <span class="font-semibold text-negro-profundo dark:text-blanco-puro">
              {item.url ? (
                <ExternalLink href={item.url} text={item.title} />
              ) : (
                item.title
              )}
              {item.description ? ": " : ""}
            </span>
          )}

          <span class="text-base md:text-[16px] text-gris-oscuro dark:text-gris-claro">
            {parseDescription(item).map((part) =>
              part.type === "link" ? (
                <ExternalLink href={part.url} text={part.text} />
              ) : (
                part.text
              )
            )}
          </span>
        </div>
      </li>
    ))}
  </ul>
)}

{isPlain && (
  <ul class="list-none p-0 m-0">
    {items.map((item) => (
      <li class="mb-2">
        {item.title && (
          <span class="font-semibold text-negro-profundo dark:text-blanco-puro">
            {item.url ? (
              <ExternalLink href={item.url} text={item.title} />
            ) : (
              item.title
            )}
            {item.description ? ": " : ""}
          </span>
        )}

        <span class="text-base md:text-[16px] text-gris-oscuro dark:text-gris-claro">
          {parseDescription(item).map((part) =>
            part.type === "link" ? (
              <ExternalLink href={part.url} text={part.text} />
            ) : (
              part.text
            )
          )}
        </span>
      </li>
    ))}
  </ul>
)}