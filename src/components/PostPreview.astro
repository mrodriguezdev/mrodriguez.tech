---
import ArrowRightIcon from "./icons/ArrowRight.astro";
import FormattedDate from "./FormattedDate.astro";

type Props = {
    post: any;
    class?: string;
};

const { post } = Astro.props;
const { title, publishDate, excerpt } = post.data;
---

<article>
    <header>
        <h3>
            {title}
        </h3>
        <FormattedDate date={publishDate} />
        {excerpt && <div>{excerpt}</div>}
    </header>
    <a href={`blog/${post.slug}/`}>
        Leer más <ArrowRightIcon />
    </a>
</article>

<style>
    article {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 0.5rem;
        margin: 2rem 0 2rem 0;
    }

    header {
        flex-grow: 1;
    }

    h3 {
        font-size: 1.25rem;
        color: var(--color-blanco-puro);
        line-height: 1.25;
        font-weight: 500;
    }

    @media (min-width: 640px) {
        h3 {
            font-size: 1.5rem;
            line-height: 2rem;
        }
    }

    div {
        margin-top: 0.75rem;
        line-height: 1.25rem;
        color: var(--color-gris-claro);
        font-size: 0.975rem;
    }

    time {
        font-size: 0.75rem;
    }

    a {
        color: var(--color-verde-lima);
        transition: 0.5s ease-in-out;
        display: flex;
        align-items: center;
    }

    a:hover {
        text-decoration-line: underline;
    }
</style>
