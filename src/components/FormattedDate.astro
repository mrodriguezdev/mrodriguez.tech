---
type Props = { date: Date };

const { date } = Astro.props;
---

<time class="text-gray-400" datetime={date.toISOString()}>
    {
        date.toLocaleDateString("es-ES", {
            timeZone: "UTC",
            year: "numeric",
            month: "short",
            day: "2-digit",
        })
    }
</time>
